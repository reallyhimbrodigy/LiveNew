{
  "expo": {
    "name": "LiveNew",
    "slug": "livenew",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/livenew-mark.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brand/livenew-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0d0a"
    },
    "ios": {
      "supportsTablet": false,
      "backgroundColor": "#0f0d0a",
      "bundleIdentifier": "app.livenew.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/livenew-mark.png",
        "backgroundColor": "#0f0d0a"
      }
    }
  }
}
